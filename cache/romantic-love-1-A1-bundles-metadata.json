        "endTime": 7.572,
        "duration": 1.756,
        "sentenceIndex": 62
      },
      {
        "text": "I could not lose Alex and I felt sad.",
        "startTime": 7.572,
        "endTime": 10.524,
        "duration": 2.953,
        "sentenceIndex": 63
      },
      {
        "text": "I saw him in secret many times.",
        "startTime": 10.524,
        "endTime": 12.998,
        "duration": 2.474,
        "sentenceIndex": 64
      },
      {
        "text": "I hid my relationship with Maya for three more years.",
        "startTime": 12.998,
        "endTime": 17.228,
        "duration": 4.23,
        "sentenceIndex": 65
      }
    ],
    "totalDuration": 17.228005,
    "measuredDuration": 17.228005
  },
  {
    "bundleId": "b11",
    "bundleIndex": 11,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-11.mp3",
    "audioPath": "romantic-love-1/A1/bundle-11.mp3",
    "sentences": [
      {
        "text": "I lied all the time and felt bad.",
