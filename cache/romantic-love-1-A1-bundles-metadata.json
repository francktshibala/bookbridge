        "endTime": 6.622,
        "duration": 2.717,
        "sentenceIndex": 55
      },
      {
        "text": "I said, \"This relationship is over,\" and I tried to explain.",
        "startTime": 6.622,
        "endTime": 12.017,
        "duration": 5.394,
        "sentenceIndex": 56
      },
      {
        "text": "I tried to show them how much Alex means to me.",
        "startTime": 12.017,
        "endTime": 16.007,
        "duration": 3.99,
        "sentenceIndex": 57
      },
      {
        "text": "But they do not listen.",
        "startTime": 16.007,
        "endTime": 17.96,
        "duration": 1.953,
        "sentenceIndex": 58
      },
      {
        "text": "My father said you made your decision coldly.",
        "startTime": 17.96,
        "endTime": 21.78,
        "duration": 3.821,
        "sentenceIndex": 59
      }
    ],
    "totalDuration": 21.780385,
    "measuredDuration": 21.780385
  },
  {
    "bundleId": "b10",
    "bundleIndex": 10,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-10.mp3",
    "audioPath": "romantic-love-1/A1/bundle-10.mp3",
    "sentences": [
      {
        "text": "What is the reason to meet him now.",
        "startTime": 0,
        "endTime": 2.793,
        "duration": 2.793,
        "sentenceIndex": 60
      },
      {
        "text": "It is too late, and I feel very sad.",
