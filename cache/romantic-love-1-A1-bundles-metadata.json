        "endTime": 16.905,
        "duration": 2.858,
        "sentenceIndex": 76
      },
      {
        "text": "My father said no and I felt sad.",
        "startTime": 16.905,
        "endTime": 19.6,
        "duration": 2.695,
        "sentenceIndex": 77
      }
    ],
    "totalDuration": 19.599819,
    "measuredDuration": 19.599819
  },
  {
    "bundleId": "b13",
    "bundleIndex": 13,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-13.mp3",
    "audioPath": "romantic-love-1/A1/bundle-13.mp3",
    "sentences": [
      {
        "text": "My mother said she understood, but I saw her disappointment.",
        "startTime": 0,
        "endTime": 4.781,
        "duration": 4.781,
        "sentenceIndex": 78
      },
      {
        "text": "I felt sad because I broke their hearts.",
