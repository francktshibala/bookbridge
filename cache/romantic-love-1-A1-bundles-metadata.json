        "endTime": 18.399,
        "duration": 2.76,
        "sentenceIndex": 71
      }
    ],
    "totalDuration": 18.399433,
    "measuredDuration": 18.399433
  },
  {
    "bundleId": "b12",
    "bundleIndex": 12,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-12.mp3",
    "audioPath": "romantic-love-1/A1/bundle-12.mp3",
    "sentences": [
      {
        "text": "My body breaks down when I hide too much.",
        "startTime": 0,
        "endTime": 3.348,
        "duration": 3.348,
        "sentenceIndex": 72
      },
      {
        "text": "I could not do it anymore and felt very tired.",
        "startTime": 3.348,
        "endTime": 7.105,
        "duration": 3.757,
        "sentenceIndex": 73
      },
      {
        "text": "I had to tell them the true story.",
        "startTime": 7.105,
        "endTime": 9.882,
        "duration": 2.777,
        "sentenceIndex": 74
      },
      {
        "text": "I told them I was still with Alex after five years.",
        "startTime": 9.882,
        "endTime": 14.047,
        "duration": 4.165,
        "sentenceIndex": 75
      },
      {
        "text": "I wanted Maya and Alex to meet him.",
