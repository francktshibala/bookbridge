        "endTime": 2.616,
        "duration": 2.616,
        "sentenceIndex": 84
      },
      {
        "text": "They said it showed that I trust him.",
        "startTime": 2.616,
        "endTime": 5.381,
        "duration": 2.765,
        "sentenceIndex": 85
      },
      {
        "text": "My father asks me to plan a dinner.",
