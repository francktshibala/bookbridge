        "endTime": 15.172,
        "duration": 2.765,
        "sentenceIndex": 89
      }
    ],
    "totalDuration": 15.172177,
    "measuredDuration": 15.172177
  },
  {
    "bundleId": "b15",
    "bundleIndex": 15,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-15.mp3",
    "audioPath": "romantic-love-1/A1/bundle-15.mp3",
    "sentences": [
      {
        "text": "What happens if they say no again.",
        "startTime": 0,
