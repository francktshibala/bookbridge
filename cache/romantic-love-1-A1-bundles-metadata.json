        "sentenceIndex": 48
      },
      {
        "text": "He picked me up and carried me home.",
        "startTime": 2.537,
        "endTime": 5.686,
        "duration": 3.149,
        "sentenceIndex": 49
      },
      {
        "text": "We stood under the stars, and he said to remember this moment.",
        "startTime": 5.686,
        "endTime": 11.26,
        "duration": 5.574,
        "sentenceIndex": 50
      },
      {
        "text": "But the hiding cannot last forever.",
        "startTime": 11.26,
        "endTime": 14.322,
        "duration": 3.062,
        "sentenceIndex": 51
      },
      {
        "text": "After two years, my parents found out my secret.",
        "startTime": 14.322,
        "endTime": 18.671,
        "duration": 4.349,
        "sentenceIndex": 52
      },
      {
        "text": "They found a message on my phone and read it.",
        "startTime": 18.671,
        "endTime": 22.608,
        "duration": 3.937,
        "sentenceIndex": 53
      }
    ],
    "totalDuration": 22.608073,
    "measuredDuration": 22.608073
  },
  {
    "bundleId": "b9",
    "bundleIndex": 9,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-9.mp3",
    "audioPath": "romantic-love-1/A1/bundle-9.mp3",
    "sentences": [
      {
        "text": "They were very angry and did not want to talk.",
        "startTime": 0,
        "endTime": 3.906,
