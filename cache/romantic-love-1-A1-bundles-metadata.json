        "endTime": 18.053,
        "duration": 4.245,
        "sentenceIndex": 82
      },
      {
        "text": "They said he should be thankful that I told him about Alex.",
        "startTime": 18.053,
        "endTime": 22.607,
        "duration": 4.554,
        "sentenceIndex": 83
      }
    ],
    "totalDuration": 22.607279,
    "measuredDuration": 22.607279
  },
  {
    "bundleId": "b14",
    "bundleIndex": 14,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-14.mp3",
    "audioPath": "romantic-love-1/A1/bundle-14.mp3",
    "sentences": [
      {
        "text": "They said it was a sign of respect.",
