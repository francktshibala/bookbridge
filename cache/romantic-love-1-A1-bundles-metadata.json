        "endTime": 9.509,
        "duration": 4.056,
        "sentenceIndex": 44
      },
      {
        "text": "I remember thinking that we had no friends.",
        "startTime": 9.509,
        "endTime": 12.677,
        "duration": 3.169,
        "sentenceIndex": 45
      },
      {
        "text": "Alex and I walked outside one night, but we persisted.",
        "startTime": 12.677,
        "endTime": 16.807,
        "duration": 4.129,
        "sentenceIndex": 46
      },
      {
        "text": "It was winter and the ground was icy.",
        "startTime": 16.807,
        "endTime": 19.533,
        "duration": 2.727,
        "sentenceIndex": 47
      }
    ],
    "totalDuration": 19.533311,
    "measuredDuration": 19.533311
  },
  {
    "bundleId": "b8",
    "bundleIndex": 8,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/romantic-love-1/A1/bundle-8.mp3",
    "audioPath": "romantic-love-1/A1/bundle-8.mp3",
    "sentences": [
      {
        "text": "I slipped but Alex caught me.",
        "startTime": 0,
        "endTime": 2.537,
