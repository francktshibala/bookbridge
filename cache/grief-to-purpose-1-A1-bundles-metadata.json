[
  {
    "bundleId": "b0",
    "bundleIndex": 0,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-0.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-0.mp3",
    "sentences": [
      {
        "text": "Anna never thought her worst day would start with a call.",
        "startTime": 0,
        "endTime": 4.489,
        "duration": 4.489,
        "sentenceIndex": 0
      },
      {
        "text": "It was a normal Tuesday morning.",
        "startTime": 4.489,
        "endTime": 7.009,
        "duration": 2.52,
        "sentenceIndex": 1
      },
      {
        "text": "She was at work and feeling busy.",
        "startTime": 7.009,
        "endTime": 9.608,
        "duration": 2.599,
        "sentenceIndex": 2
      },
      {
        "text": "Suddenly, her phone rang loudly.",
        "startTime": 9.608,
        "endTime": 12.279,
        "duration": 2.67,
        "sentenceIndex": 3
      },
      {
        "text": "The voice on the other end was calm but felt urgent.",
        "startTime": 12.279,
        "endTime": 16.374,
        "duration": 4.095,
        "sentenceIndex": 4
      },
      {
        "text": "“Hello, this is the hospital,” the voice said.",
        "startTime": 16.374,
        "endTime": 20.297,
        "duration": 3.923,
        "sentenceIndex": 5
      }
    ],
    "totalDuration": 20.296735,
    "measuredDuration": 20.296735
  },
  {
    "bundleId": "b1",
    "bundleIndex": 1,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-1.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-1.mp3",
    "sentences": [
      {
        "text": "“There was an accident.” Anna's heart began to race.",
        "startTime": 0,
        "endTime": 3.737,
        "duration": 3.737,
        "sentenceIndex": 6
      },
      {
        "text": "“Your son Ethan is eight years old,” the voice continued.",
        "startTime": 3.737,
        "endTime": 7.983,
        "duration": 4.246,
        "sentenceIndex": 7
      },
      {
        "text": "“He is at the hospital.” Anna's world stops when she feels very sad.",
        "startTime": 7.983,
        "endTime": 12.87,
        "duration": 4.887,
        "sentenceIndex": 8
      },
      {
        "text": "She dropped everything and ran to her car with shaking hands.",
        "startTime": 12.87,
        "endTime": 17.253,
        "duration": 4.384,
        "sentenceIndex": 9
      },
      {
        "text": "The drive to the hospital felt long but was only fifteen minutes.",
        "startTime": 17.253,
        "endTime": 21.924,
        "duration": 4.671,
        "sentenceIndex": 10
      },
      {
        "text": "Each second felt like an hour.",
        "startTime": 21.924,
        "endTime": 24.08,
        "duration": 2.156,
        "sentenceIndex": 11
      }
    ],
    "totalDuration": 24.080136,
    "measuredDuration": 24.080136
  },
  {
    "bundleId": "b2",
    "bundleIndex": 2,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-2.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-2.mp3",
    "sentences": [
      {
        "text": "Her thoughts were a blur.",
        "startTime": 0,
        "endTime": 2.217,
        "duration": 2.217,
        "sentenceIndex": 12
      },
      {
        "text": "When she arrived, the doctors waited for her.",
        "startTime": 2.217,
        "endTime": 6.358,
        "duration": 4.141,
        "sentenceIndex": 13
      },
      {
        "text": "They looked serious and sad.",
        "startTime": 6.358,
        "endTime": 8.841,
        "duration": 2.483,
        "sentenceIndex": 14
      },
      {
        "text": "They told her Ethan was hit by a car after school.",
        "startTime": 8.841,
        "endTime": 13.275,
        "duration": 4.434,
        "sentenceIndex": 15
      },
      {
        "text": "“He died quickly and did not feel pain,” the doctor said gently.",
        "startTime": 13.275,
        "endTime": 19.101,
        "duration": 5.826,
        "sentenceIndex": 16
      },
      {
        "text": "Anna could not understand.",
        "startTime": 19.101,
        "endTime": 21.406,
        "duration": 2.306,
        "sentenceIndex": 17
      }
    ],
    "totalDuration": 21.406281,
    "measuredDuration": 21.406281
  },
  {
    "bundleId": "b3",
    "bundleIndex": 3,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-3.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-3.mp3",
    "sentences": [
      {
        "text": "The words do not make sense at first.",
        "startTime": 0,
        "endTime": 2.845,
        "duration": 2.845,
        "sentenceIndex": 18
      },
      {
        "text": "Did someone die or is it just a question?",
        "startTime": 2.845,
        "endTime": 5.997,
        "duration": 3.152,
        "sentenceIndex": 19
      },
      {
        "text": "Is her son here or not?",
        "startTime": 5.997,
        "endTime": 7.766,
        "duration": 1.768,
        "sentenceIndex": 20
      },
      {
        "text": "No, that is not right.",
        "startTime": 7.766,
        "endTime": 9.607,
        "duration": 1.842,
        "sentenceIndex": 21
      },
      {
        "text": "Ethan was to come home that afternoon, but he did not.",
        "startTime": 9.607,
        "endTime": 13.91,
        "duration": 4.302,
        "sentenceIndex": 22
      },
      {
        "text": "He was meant to do his homework but did not.",
        "startTime": 13.91,
        "endTime": 17.293,
        "duration": 3.383,
        "sentenceIndex": 23
      }
    ],
    "totalDuration": 17.292653,
    "measuredDuration": 17.292653
  },
  {
    "bundleId": "b4",
    "bundleIndex": 4,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-4.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-4.mp3",
    "sentences": [
      {
        "text": "He was to have dinner with her.",
        "startTime": 0,
        "endTime": 2.276,
        "duration": 2.276,
        "sentenceIndex": 24
      },
      {
        "text": "They always had dinner together.",
        "startTime": 2.276,
        "endTime": 4.625,
        "duration": 2.349,
        "sentenceIndex": 25
      },
      {
        "text": "He grows up, goes to college, and has a family.",
        "startTime": 4.625,
        "endTime": 8.375,
        "duration": 3.75,
        "sentenceIndex": 26
      },
      {
        "text": "He was meant to bury her, but it was the other way.",
        "startTime": 8.375,
        "endTime": 12.269,
        "duration": 3.894,
        "sentenceIndex": 27
      },
      {
        "text": "Anna realized the doctors were still talking and asking her questions.",
        "startTime": 12.269,
        "endTime": 17.407,
        "duration": 5.139,
        "sentenceIndex": 28
      },
      {
        "text": "What does she want to do now?",
        "startTime": 17.407,
        "endTime": 19.536,
        "duration": 2.129,
        "sentenceIndex": 29
      }
    ],
    "totalDuration": 19.536009,
    "measuredDuration": 19.536009
  },
  {
    "bundleId": "b5",
    "bundleIndex": 5,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-5.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-5.mp3",
    "sentences": [
      {
        "text": "Did she want to see Ethan?",
        "startTime": 0,
        "endTime": 1.977,
        "duration": 1.977,
        "sentenceIndex": 30
      },
      {
        "text": "Did she want to pick clothes for him?",
        "startTime": 1.977,
        "endTime": 4.791,
        "duration": 2.813,
        "sentenceIndex": 31
      },
      {
        "text": "The questions feel very hard and make her worried.",
        "startTime": 4.791,
        "endTime": 8.593,
        "duration": 3.802,
        "sentenceIndex": 32
      },
      {
        "text": "How can Anna choose clothes for Ethan if he won't wear them?",
        "startTime": 8.593,
        "endTime": 13.155,
        "duration": 4.562,
        "sentenceIndex": 33
      },
      {
        "text": "How can she think about what he wears when he is gone?",
        "startTime": 13.155,
        "endTime": 17.261,
        "duration": 4.106,
        "sentenceIndex": 34
      },
      {
        "text": "Still, she went home and felt alone.",
        "startTime": 17.261,
        "endTime": 20.149,
        "duration": 2.887,
        "sentenceIndex": 35
      }
    ],
    "totalDuration": 20.148617,
    "measuredDuration": 20.148617
  },
  {
    "bundleId": "b6",
    "bundleIndex": 6,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-6.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-6.mp3",
    "sentences": [
      {
        "text": "Each step felt heavy.",
        "startTime": 0,
        "endTime": 1.603,
        "duration": 1.603,
        "sentenceIndex": 36
      },
      {
        "text": "Anna walked into Ethan's room and saw his drawing on the desk.",
        "startTime": 1.603,
        "endTime": 6.334,
        "duration": 4.731,
        "sentenceIndex": 37
      },
      {
        "text": "It was colorful and bright.",
        "startTime": 6.334,
        "endTime": 8.395,
        "duration": 2.06,
        "sentenceIndex": 38
      },
      {
        "text": "It showed a heart and said, \"I love you, Mom.\" \n\nAnna picked it up and cried for the first time.",
        "startTime": 8.395,
        "endTime": 16.021,
        "duration": 7.626,
        "sentenceIndex": 39
      },
      {
        "text": "Tears fell down her cheeks.",
        "startTime": 16.021,
        "endTime": 18.081,
        "duration": 2.06,
        "sentenceIndex": 40
      },
      {
        "text": "She opened Ethan's closet and looked at his clothes.",
        "startTime": 18.081,
        "endTime": 22.05,
        "duration": 3.968,
        "sentenceIndex": 41
      }
    ],
    "totalDuration": 22.049546,
    "measuredDuration": 22.049546
  },
  {
    "bundleId": "b7",
    "bundleIndex": 7,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-7.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-7.mp3",
    "sentences": [
      {
        "text": "Each shirt and pair of pants reminded her of him.",
        "startTime": 0,
        "endTime": 3.734,
        "duration": 3.734,
        "sentenceIndex": 42
      },
      {
        "text": "She chose his blue sweater because he wanted to wear it.",
        "startTime": 3.734,
        "endTime": 8.002,
        "duration": 4.268,
        "sentenceIndex": 43
      },
      {
        "text": "It was his favorite.",
        "startTime": 8.002,
        "endTime": 9.526,
        "duration": 1.524,
        "sentenceIndex": 44
      },
      {
        "text": "She chose the jeans that he likes best.",
        "startTime": 9.526,
        "endTime": 12.498,
        "duration": 2.972,
        "sentenceIndex": 45
      },
      {
        "text": "They fit him perfectly.",
        "startTime": 12.498,
        "endTime": 14.251,
        "duration": 1.753,
        "sentenceIndex": 46
      },
      {
        "text": "She chose warm socks so her boy would not be cold.",
        "startTime": 14.251,
        "endTime": 18.061,
        "duration": 3.81,
        "sentenceIndex": 47
      }
    ],
    "totalDuration": 18.061474,
    "measuredDuration": 18.061474
  },
  {
    "bundleId": "b8",
    "bundleIndex": 8,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-8.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-8.mp3",
    "sentences": [
      {
        "text": "The thought makes her cry more and feel sad.",
        "startTime": 0,
        "endTime": 3.29,
        "duration": 3.29,
        "sentenceIndex": 48
      },
      {
        "text": "He will never feel warm or cold again.",
        "startTime": 3.29,
        "endTime": 6.131,
        "duration": 2.841,
        "sentenceIndex": 49
      },
      {
        "text": "He will never feel anything again.",
        "startTime": 6.131,
        "endTime": 8.673,
        "duration": 2.542,
        "sentenceIndex": 50
      },
      {
        "text": "The days after that were very confusing and unclear.",
        "startTime": 8.673,
        "endTime": 12.56,
        "duration": 3.888,
        "sentenceIndex": 51
      },
      {
        "text": "Friends and family come to visit Anna and Ethan.",
        "startTime": 12.56,
        "endTime": 16.149,
        "duration": 3.589,
        "sentenceIndex": 52
      },
      {
        "text": "They brought food and shared it with everyone.",
        "startTime": 16.149,
        "endTime": 19.588,
        "duration": 3.439,
        "sentenceIndex": 53
      }
    ],
    "totalDuration": 19.587937,
    "measuredDuration": 19.587937
  },
  {
    "bundleId": "b9",
    "bundleIndex": 9,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-9.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-9.mp3",
    "sentences": [
      {
        "text": "Some brought cookies and cakes.",
        "startTime": 0,
        "endTime": 2.446,
        "duration": 2.446,
        "sentenceIndex": 54
      },
      {
        "text": "They brought flowers and gave them to Anna.",
        "startTime": 2.446,
        "endTime": 5.839,
        "duration": 3.393,
        "sentenceIndex": 55
      },
      {
        "text": "The flowers smelled sweet, but they did not help.",
        "startTime": 5.839,
        "endTime": 9.855,
        "duration": 4.016,
        "sentenceIndex": 56
      },
      {
        "text": "They brought words of comfort, but Anna could not hear them.",
        "startTime": 9.855,
        "endTime": 14.739,
        "duration": 4.884,
        "sentenceIndex": 57
      },
      {
        "text": "She moved through each day slowly and felt far away.",
        "startTime": 14.739,
        "endTime": 18.842,
        "duration": 4.103,
        "sentenceIndex": 58
      },
      {
        "text": "She felt like she was in a dream.",
        "startTime": 18.842,
        "endTime": 21.445,
        "duration": 2.604,
        "sentenceIndex": 59
      }
    ],
    "totalDuration": 21.445351,
    "measuredDuration": 21.445351
  },
  {
    "bundleId": "b10",
    "bundleIndex": 10,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-10.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-10.mp3",
    "sentences": [
      {
        "text": "She went to the funeral and felt very sad.",
        "startTime": 0,
        "endTime": 3.36,
        "duration": 3.36,
        "sentenceIndex": 60
      },
      {
        "text": "The sky was gray that day.",
        "startTime": 3.36,
        "endTime": 5.44,
        "duration": 2.08,
        "sentenceIndex": 61
      },
      {
        "text": "She watched them lower her son's small casket into the ground.",
        "startTime": 5.44,
        "endTime": 10.399,
        "duration": 4.96,
        "sentenceIndex": 62
      },
      {
        "text": "It was so tiny.",
        "startTime": 10.399,
        "endTime": 11.599,
        "duration": 1.2,
        "sentenceIndex": 63
      },
      {
        "text": "She went home to a house that now feels empty.",
        "startTime": 11.599,
        "endTime": 15.279,
        "duration": 3.68,
        "sentenceIndex": 64
      },
      {
        "text": "The silence was painful.",
        "startTime": 15.279,
        "endTime": 17.199,
        "duration": 1.92,
        "sentenceIndex": 65
      }
    ],
    "totalDuration": 17.198685,
    "measuredDuration": 17.198685
  },
  {
    "bundleId": "b11",
    "bundleIndex": 11,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-11.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-11.mp3",
    "sentences": [
      {
        "text": "Weeks go by and time changes.",
        "startTime": 0,
        "endTime": 2.66,
        "duration": 2.66,
        "sentenceIndex": 66
      },
      {
        "text": "Then there are months.",
        "startTime": 2.66,
        "endTime": 4.678,
        "duration": 2.018,
        "sentenceIndex": 67
      },
      {
        "text": "Anna went back to work but felt like a new person.",
        "startTime": 4.678,
        "endTime": 9.264,
        "duration": 4.586,
        "sentenceIndex": 68
      },
      {
        "text": "She did her daily tasks, but nothing felt real to her.",
        "startTime": 9.264,
        "endTime": 14.367,
        "duration": 5.103,
        "sentenceIndex": 69
      },
      {
        "text": "It was like she was on autopilot.",
        "startTime": 14.367,
        "endTime": 17.394,
        "duration": 3.027,
        "sentenceIndex": 70
      },
      {
        "text": "Anna wakes up and forgets for a moment, but then remembers Ethan is gone.",
        "startTime": 17.394,
        "endTime": 24.24,
        "duration": 6.846,
        "sentenceIndex": 71
      }
    ],
    "totalDuration": 24.239569,
    "measuredDuration": 24.239569
  },
  {
    "bundleId": "b12",
    "bundleIndex": 12,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-12.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-12.mp3",
    "sentences": [
      {
        "text": "Each morning was hard.",
        "startTime": 0,
        "endTime": 1.814,
        "duration": 1.814,
        "sentenceIndex": 72
      },
      {
        "text": "One afternoon, Anna cleaned Ethan's room six months after his death.",
        "startTime": 1.814,
        "endTime": 7.572,
        "duration": 5.757,
        "sentenceIndex": 73
      },
      {
        "text": "She put it off but knew she must not leave it forever.",
        "startTime": 7.572,
        "endTime": 12.024,
        "duration": 4.453,
        "sentenceIndex": 74
      },
      {
        "text": "She organized his books and found a notebook.",
        "startTime": 12.024,
        "endTime": 15.735,
        "duration": 3.711,
        "sentenceIndex": 75
      },
      {
        "text": "It was blue and had stickers on it.",
        "startTime": 15.735,
        "endTime": 18.621,
        "duration": 2.886,
        "sentenceIndex": 76
      },
      {
        "text": "Ethan wrote a list inside the notebook.",
        "startTime": 18.621,
        "endTime": 21.837,
        "duration": 3.216,
        "sentenceIndex": 77
      }
    ],
    "totalDuration": 21.837347,
    "measuredDuration": 21.837347
  },
  {
    "bundleId": "b13",
    "bundleIndex": 13,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-13.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-13.mp3",
    "sentences": [
      {
        "text": "Anna sat on the floor and read the list of kind ideas.",
        "startTime": 0,
        "endTime": 4.251,
        "duration": 4.251,
        "sentenceIndex": 78
      },
      {
        "text": "Her son thinks about helping others.",
        "startTime": 4.251,
        "endTime": 7.085,
        "duration": 2.834,
        "sentenceIndex": 79
      },
      {
        "text": "At eight years old, he wanted to make the world better.",
        "startTime": 7.085,
        "endTime": 11.565,
        "duration": 4.48,
        "sentenceIndex": 80
      },
      {
        "text": "He wrote about sharing toys, helping friends, and being kind.",
        "startTime": 11.565,
        "endTime": 16.667,
        "duration": 5.102,
        "sentenceIndex": 81
      },
      {
        "text": "And now he will never do it again.",
        "startTime": 16.667,
        "endTime": 19.343,
        "duration": 2.677,
        "sentenceIndex": 82
      },
      {
        "text": "But then Anna had a new idea.",
        "startTime": 19.343,
        "endTime": 21.626,
        "duration": 2.283,
        "sentenceIndex": 83
      }
    ],
    "totalDuration": 21.626417,
    "measuredDuration": 21.626417
  },
  {
    "bundleId": "b14",
    "bundleIndex": 14,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/grief-to-purpose-1/A1/bundle-14.mp3",
    "audioPath": "grief-to-purpose-1/A1/bundle-14.mp3",
    "sentences": [
      {
