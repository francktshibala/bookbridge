        "sentenceIndex": 55
      },
      {
        "text": "This one is very rare and has a six percent chance to live.",
        "startTime": 4.962,
        "endTime": 9.873,
        "duration": 4.911,
        "sentenceIndex": 56
      },
      {
        "text": "They told him he has two weeks to live.",
