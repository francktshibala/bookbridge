    "audioPath": "youth-activism-1/A1/bundle-20.mp3",
    "sentences": [
      {
        "text": "Emma reached her goal and felt very happy.",
        "startTime": 0,
        "endTime": 2.927,
        "duration": 2.927,
        "sentenceIndex": 100
      },
      {
        "text": "She collected many books from different countries and loved them.",
