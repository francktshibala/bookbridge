    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/youth-activism-1/A1/bundle-19.mp3",
    "audioPath": "youth-activism-1/A1/bundle-19.mp3",
    "sentences": [
      {
        "text": "Option one: focus on herself and get more books.",
        "startTime": 0,
        "endTime": 3.692,
        "duration": 3.692,
        "sentenceIndex": 95
