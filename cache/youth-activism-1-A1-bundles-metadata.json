    "audioPath": "youth-activism-1/A1/bundle-18.mp3",
    "sentences": [
      {
        "text": "Emma saw that this pattern happened often.",
        "startTime": 0,
        "endTime": 2.922,
        "duration": 2.922,
        "sentenceIndex": 90
      },
      {
        "text": "She feels frustrated when things do not go well.",
        "startTime": 2.922,
        "endTime": 6.262,
        "duration": 3.34,
        "sentenceIndex": 91
      },
      {
        "text": "Emma liked the stories and her teacher, but she wanted more.",
        "startTime": 6.262,
        "endTime": 10.587,
        "duration": 4.325,
        "sentenceIndex": 92
      },
      {
        "text": "She wanted to see other people and their stories.",
        "startTime": 10.587,
        "endTime": 13.997,
        "duration": 3.41,
        "sentenceIndex": 93
      },
      {
        "text": "Emma has three choices.",
