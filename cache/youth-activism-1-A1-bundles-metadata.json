        "text": "Maya was not the only young person who helped others.",
        "startTime": 0,
        "endTime": 3.916,
        "duration": 3.916,
        "sentenceIndex": 85
      },
      {
        "text": "Emma was eleven years old and felt frustrated.",
        "startTime": 3.916,
        "endTime": 7.315,
        "duration": 3.399,
        "sentenceIndex": 86
      },
      {
        "text": "Every book in her class has white boys and their dogs.",
        "startTime": 7.315,
        "endTime": 11.305,
        "duration": 3.99,
        "sentenceIndex": 87
      },
      {
        "text": "Emma reads five books in one year.",
        "startTime": 11.305,
        "endTime": 13.817,
        "duration": 2.512,
        "sentenceIndex": 88
      },
      {
        "text": "There are no characters who look like her.",
        "startTime": 13.817,
        "endTime": 16.92,
        "duration": 3.103,
        "sentenceIndex": 89
      }
    ],
    "totalDuration": 16.920317,
    "measuredDuration": 16.920317
  },
  {
