[
  {
    "bundleId": "b0",
    "bundleIndex": 0,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-0.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-0.mp3",
    "sentences": [
      {
        "text": "Isabella made the hardest choice of her life.",
        "startTime": 0,
        "endTime": 3.127,
        "duration": 3.127,
        "sentenceIndex": 0
      },
      {
        "text": "She has to leave now because she is busy.",
        "startTime": 3.127,
        "endTime": 5.976,
        "duration": 2.849,
        "sentenceIndex": 1
      },
      {
        "text": "It is not safe now.",
        "startTime": 5.976,
        "endTime": 7.296,
        "duration": 1.32,
        "sentenceIndex": 2
      },
      {
        "text": "Her husband was violent, and she felt very scared.",
        "startTime": 7.296,
        "endTime": 10.921,
        "duration": 3.624,
        "sentenceIndex": 3
      },
      {
        "text": "Isabella's heart raced as she thought about what could happen if she stayed.",
        "startTime": 10.921,
        "endTime": 16.202,
        "duration": 5.281,
        "sentenceIndex": 4
      },
      {
        "text": "She knew that if she stayed, she might not live.",
        "startTime": 16.202,
        "endTime": 19.688,
        "duration": 3.486,
        "sentenceIndex": 5
      }
    ],
    "totalDuration": 19.68771,
    "measuredDuration": 19.68771
  },
  {
    "bundleId": "b1",
    "bundleIndex": 1,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-1.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-1.mp3",
    "sentences": [
      {
        "text": "Isabella took her two children, Gabriel and Olivia, and left everything behind.",
        "startTime": 0,
        "endTime": 6.225,
        "duration": 6.225,
        "sentenceIndex": 6
      },
      {
        "text": "They had no place to go.",
        "startTime": 6.225,
        "endTime": 8.025,
        "duration": 1.8,
        "sentenceIndex": 7
      },
      {
        "text": "Isabella felt a heavy weight in her chest as she walked away.",
        "startTime": 8.025,
        "endTime": 12.6,
        "duration": 4.575,
        "sentenceIndex": 8
      },
      {
        "text": "She had no job and no family near her.",
        "startTime": 12.6,
        "endTime": 15.45,
        "duration": 2.85,
        "sentenceIndex": 9
      },
      {
        "text": "She felt very alone.",
        "startTime": 15.45,
        "endTime": 16.951,
        "duration": 1.5,
        "sentenceIndex": 10
      },
      {
        "text": "She called for help, her voice trembling.",
        "startTime": 16.951,
        "endTime": 20.176,
        "duration": 3.225,
        "sentenceIndex": 11
      }
    ],
    "totalDuration": 20.175601,
    "measuredDuration": 20.175601
  },
  {
    "bundleId": "b2",
    "bundleIndex": 2,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-2.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-2.mp3",
    "sentences": [
      {
        "text": "They sent her to a shelter.",
        "startTime": 0,
        "endTime": 2.374,
        "duration": 2.374,
        "sentenceIndex": 12
      },
      {
        "text": "The shelter was full, so they stayed in a small hotel.",
        "startTime": 2.374,
        "endTime": 7.273,
        "duration": 4.899,
        "sentenceIndex": 13
      },
      {
        "text": "It was small but safe for everyone.",
        "startTime": 7.273,
        "endTime": 10.351,
        "duration": 3.078,
        "sentenceIndex": 14
      },
      {
        "text": "Isabella felt safe for the first time in years.",
        "startTime": 10.351,
        "endTime": 14.485,
        "duration": 4.133,
        "sentenceIndex": 15
      },
      {
        "text": "Safety has a cost, but it is important.",
        "startTime": 14.485,
        "endTime": 18.064,
        "duration": 3.58,
        "sentenceIndex": 16
      },
      {
        "text": "Isabella felt embarrassed because of what happened.",
        "startTime": 18.064,
        "endTime": 22.549,
        "duration": 4.485,
        "sentenceIndex": 17
      }
    ],
    "totalDuration": 22.549478,
    "measuredDuration": 22.549478
  },
  {
    "bundleId": "b3",
    "bundleIndex": 3,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-3.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-3.mp3",
    "sentences": [
      {
        "text": "She felt bad and was ashamed of her situation.",
        "startTime": 0,
        "endTime": 3.411,
        "duration": 3.411,
        "sentenceIndex": 18
      },
      {
        "text": "She had always wanted to be a good mother.",
        "startTime": 3.411,
        "endTime": 6.526,
        "duration": 3.115,
        "sentenceIndex": 19
      },
      {
        "text": "She failed and felt very sad about it.",
        "startTime": 6.526,
        "endTime": 9.344,
        "duration": 2.818,
        "sentenceIndex": 20
      },
      {
        "text": "She could not keep her family together and felt sorrow in her heart.",
        "startTime": 9.344,
        "endTime": 14.387,
        "duration": 5.043,
        "sentenceIndex": 21
      },
      {
        "text": "She did not give her children a safe home.",
        "startTime": 14.387,
        "endTime": 17.502,
        "duration": 3.115,
        "sentenceIndex": 22
      },
      {
        "text": "She felt everyone saw her failure and judged her.",
        "startTime": 17.502,
        "endTime": 21.136,
        "duration": 3.634,
        "sentenceIndex": 23
      }
    ],
    "totalDuration": 21.135646,
    "measuredDuration": 21.135646
  },
  {
    "bundleId": "b4",
    "bundleIndex": 4,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-4.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-4.mp3",
    "sentences": [
      {
        "text": "The hotel room is their home for now, but it felt strange.",
        "startTime": 0,
        "endTime": 4.418,
        "duration": 4.418,
        "sentenceIndex": 24
      },
      {
        "text": "Isabella tried to help the children feel normal and happy.",
        "startTime": 4.418,
        "endTime": 8.685,
        "duration": 4.268,
        "sentenceIndex": 25
      },
      {
        "text": "She hung their colorful drawings on the walls and smiled at them.",
        "startTime": 8.685,
        "endTime": 13.468,
        "duration": 4.783,
        "sentenceIndex": 26
      },
      {
        "text": "She read bedtime stories to them at night.",
        "startTime": 13.468,
        "endTime": 16.558,
        "duration": 3.09,
        "sentenceIndex": 27
      },
      {
        "text": "“Once upon a time,” she would begin, and the children would listen closely.",
        "startTime": 16.558,
        "endTime": 22.376,
        "duration": 5.818,
        "sentenceIndex": 28
      },
      {
        "text": "She tried to smile but wanted to cry at the same time.",
        "startTime": 22.376,
        "endTime": 26.35,
        "duration": 3.973,
        "sentenceIndex": 29
      }
    ],
    "totalDuration": 26.349615,
    "measuredDuration": 26.349615
  },
  {
    "bundleId": "b5",
    "bundleIndex": 5,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-5.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-5.mp3",
    "sentences": [
      {
        "text": "But inside, she felt like she was breaking apart.",
        "startTime": 0,
        "endTime": 3.695,
        "duration": 3.695,
        "sentenceIndex": 30
      },
      {
        "text": "After three months in the hotel, Isabella got help for her family.",
        "startTime": 3.695,
        "endTime": 8.619,
        "duration": 4.924,
        "sentenceIndex": 31
      },
      {
        "text": "She met mentors who felt like family to her.",
        "startTime": 8.619,
        "endTime": 11.802,
        "duration": 3.183,
        "sentenceIndex": 32
      },
      {
        "text": "They helped her find a job and believe in herself again.",
        "startTime": 11.802,
        "endTime": 15.853,
        "duration": 4.051,
        "sentenceIndex": 33
      },
      {
        "text": "\"You can do this, Isabella,\" one mentor said with a warm smile.",
        "startTime": 15.853,
        "endTime": 20.71,
        "duration": 4.857,
        "sentenceIndex": 34
      },
      {
        "text": "The journey was long, but they kept going.",
        "startTime": 20.71,
        "endTime": 23.898,
        "duration": 3.188,
        "sentenceIndex": 35
      }
    ],
    "totalDuration": 23.898073,
    "measuredDuration": 23.898073
  },
  {
    "bundleId": "b6",
    "bundleIndex": 6,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-6.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-6.mp3",
    "sentences": [
      {
        "text": "Isabella moved between shelters and finally found a small apartment.",
        "startTime": 0,
        "endTime": 4.965,
        "duration": 4.965,
        "sentenceIndex": 36
      },
      {
        "text": "The apartment was not great, but it was Isabella's home.",
        "startTime": 4.965,
        "endTime": 9.204,
        "duration": 4.239,
        "sentenceIndex": 37
      },
      {
        "text": "It had two bedrooms, a small kitchen, and a living room.",
        "startTime": 9.204,
        "endTime": 13.593,
        "duration": 4.389,
        "sentenceIndex": 38
      },
      {
        "text": "Isabella had a door that locked, and she controlled who entered.",
        "startTime": 13.593,
        "endTime": 18.416,
        "duration": 4.823,
        "sentenceIndex": 39
      },
      {
        "text": "For the first time in years, she felt control over her life.",
        "startTime": 18.416,
        "endTime": 22.947,
        "duration": 4.531,
        "sentenceIndex": 40
      },
      {
        "text": "But the struggle was not over now.",
        "startTime": 22.947,
        "endTime": 25.429,
        "duration": 2.483,
        "sentenceIndex": 41
      }
    ],
    "totalDuration": 25.429206,
    "measuredDuration": 25.429206
  },
  {
    "bundleId": "b7",
    "bundleIndex": 7,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-7.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-7.mp3",
    "sentences": [
      {
        "text": "Isabella worked two jobs, one in a store and one at night.",
        "startTime": 0,
        "endTime": 4.256,
        "duration": 4.256,
        "sentenceIndex": 42
      },
      {
        "text": "She felt exhausted every day.",
        "startTime": 4.256,
        "endTime": 6.309,
        "duration": 2.053,
        "sentenceIndex": 43
      },
      {
        "text": "Isabella came home tired and helped Gabriel with his homework.",
        "startTime": 6.309,
        "endTime": 10.698,
        "duration": 4.389,
        "sentenceIndex": 44
      },
      {
        "text": "She read to Olivia, who loved stories about adventures.",
        "startTime": 10.698,
        "endTime": 14.742,
        "duration": 4.044,
        "sentenceIndex": 45
      },
      {
        "text": "Some nights, she sat in her car and cried after work.",
        "startTime": 14.742,
        "endTime": 18.644,
        "duration": 3.902,
        "sentenceIndex": 46
      },
      {
        "text": "She felt invisible and alone sometimes.",
        "startTime": 18.644,
        "endTime": 21.405,
        "duration": 2.761,
        "sentenceIndex": 47
      }
    ],
    "totalDuration": 21.404603,
    "measuredDuration": 21.404603
  },
  {
    "bundleId": "b8",
    "bundleIndex": 8,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-8.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-8.mp3",
    "sentences": [
      {
        "text": "The people she cleaned for did not know her name.",
        "startTime": 0,
        "endTime": 3.721,
        "duration": 3.721,
        "sentenceIndex": 48
      },
      {
        "text": "They did not see her as a person but as a cleaner.",
        "startTime": 3.721,
        "endTime": 7.518,
        "duration": 3.797,
        "sentenceIndex": 49
      },
      {
        "text": "Isabella came home one evening and found Gabriel crying.",
        "startTime": 7.518,
        "endTime": 11.77,
        "duration": 4.252,
        "sentenceIndex": 50
      },
      {
        "text": "His face was red and puffy.",
        "startTime": 11.77,
        "endTime": 13.82,
        "duration": 2.05,
        "sentenceIndex": 51
      },
      {
        "text": "“What’s wrong, sweetheart?” she asked, worried.",
        "startTime": 13.82,
        "endTime": 17.689,
        "duration": 3.869,
        "sentenceIndex": 52
      },
      {
        "text": "He was bullied at school and felt very sad.",
        "startTime": 17.689,
        "endTime": 20.955,
        "duration": 3.265,
        "sentenceIndex": 53
      }
    ],
    "totalDuration": 20.954762,
    "measuredDuration": 20.954762
  },
  {
    "bundleId": "b9",
    "bundleIndex": 9,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-9.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-9.mp3",
    "sentences": [
      {
        "text": "The other kids made fun of him because he had old clothes.",
        "startTime": 0,
        "endTime": 4.392,
        "duration": 4.392,
        "sentenceIndex": 54
      },
      {
        "text": "Isabella held her son tightly and cried with him.",
        "startTime": 4.392,
        "endTime": 8.103,
        "duration": 3.711,
        "sentenceIndex": 55
      },
      {
        "text": "She felt bad because she thought she failed him.",
        "startTime": 8.103,
        "endTime": 11.738,
        "duration": 3.635,
        "sentenceIndex": 56
      },
      {
        "text": "“I’m so sorry, Gabriel,” she whispered.",
        "startTime": 11.738,
        "endTime": 14.992,
        "duration": 3.254,
        "sentenceIndex": 57
      },
      {
        "text": "She felt like she was failing her children, Isabella and Gabriel.",
        "startTime": 14.992,
        "endTime": 20.065,
        "duration": 5.073,
        "sentenceIndex": 58
      },
      {
        "text": "She could not give them the life they needed.",
        "startTime": 20.065,
        "endTime": 23.473,
        "duration": 3.408,
        "sentenceIndex": 59
      }
    ],
    "totalDuration": 23.472562,
    "measuredDuration": 23.472562
  },
  {
    "bundleId": "b10",
    "bundleIndex": 10,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-10.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-10.mp3",
    "sentences": [
      {
        "text": "She could not protect them from the world's bad things.",
        "startTime": 0,
        "endTime": 3.794,
        "duration": 3.794,
        "sentenceIndex": 60
      },
      {
        "text": "That night, Isabella made a choice and felt strong.",
        "startTime": 3.794,
        "endTime": 7.461,
        "duration": 3.668,
        "sentenceIndex": 61
      },
      {
        "text": "She remembered her love for crafting.",
        "startTime": 7.461,
        "endTime": 10.013,
        "duration": 2.552,
        "sentenceIndex": 62
      },
      {
        "text": "She was always good with her hands and made things.",
        "startTime": 10.013,
        "endTime": 13.531,
        "duration": 3.518,
        "sentenceIndex": 63
      },
      {
        "text": "She always loved to create new things.",
        "startTime": 13.531,
        "endTime": 16.152,
        "duration": 2.621,
        "sentenceIndex": 64
      },
      {
        "text": "When she was young, she dreamed of her own business, but life changed.",
        "startTime": 16.152,
        "endTime": 21.28,
        "duration": 5.128,
        "sentenceIndex": 65
      }
    ],
    "totalDuration": 21.280499,
    "measuredDuration": 21.280499
  },
  {
    "bundleId": "b11",
    "bundleIndex": 11,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-11.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-11.mp3",
    "sentences": [
      {
        "text": "She decided to try anyway because she wanted to succeed and give her children a better life.",
        "startTime": 0,
        "endTime": 6.532,
        "duration": 6.532,
        "sentenceIndex": 66
      },
      {
        "text": "Isabella started to make jewelry in the morning and at night when the kids slept.",
        "startTime": 6.532,
        "endTime": 12.282,
        "duration": 5.751,
        "sentenceIndex": 67
      },
      {
        "text": "She would sit at the table, her fingers busy with beads and wires.",
        "startTime": 12.282,
        "endTime": 17.118,
        "duration": 4.836,
        "sentenceIndex": 68
      },
      {
        "text": "Isabella made a small online store and sold her jewelry.",
        "startTime": 17.118,
        "endTime": 21.094,
        "duration": 3.976,
        "sentenceIndex": 69
      },
      {
        "text": "At first, she sold to friends and family.",
        "startTime": 21.094,
        "endTime": 24.155,
        "duration": 3.061,
        "sentenceIndex": 70
      },
      {
        "text": "Then, strangers started to buy her things, and they were happy.",
        "startTime": 24.155,
        "endTime": 28.927,
        "duration": 4.773,
        "sentenceIndex": 71
      }
    ],
    "totalDuration": 28.927234,
    "measuredDuration": 28.927234
  },
  {
    "bundleId": "b12",
    "bundleIndex": 12,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-12.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-12.mp3",
    "sentences": [
      {
        "text": "The business grew slowly, but it still grew.",
        "startTime": 0,
        "endTime": 3.415,
        "duration": 3.415,
        "sentenceIndex": 72
      },
      {
        "text": "Isabella used all her money to buy better materials and learn new skills.",
        "startTime": 3.415,
        "endTime": 8.832,
        "duration": 5.417,
        "sentenceIndex": 73
      },
      {
        "text": "She watched online videos and practiced every night.",
        "startTime": 8.832,
        "endTime": 12.69,
        "duration": 3.859,
        "sentenceIndex": 74
      },
      {
        "text": "But it was not enough for Isabella.",
        "startTime": 12.69,
        "endTime": 15.287,
        "duration": 2.597,
        "sentenceIndex": 75
      },
      {
        "text": "She needed her two jobs to pay the bills.",
        "startTime": 15.287,
        "endTime": 18.33,
        "duration": 3.042,
        "sentenceIndex": 76
      },
      {
        "text": "Isabella was tired because she worked three jobs now.",
        "startTime": 18.33,
        "endTime": 22.262,
        "duration": 3.933,
        "sentenceIndex": 77
      }
    ],
    "totalDuration": 22.262358,
    "measuredDuration": 22.262358
  },
  {
    "bundleId": "b13",
    "bundleIndex": 13,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-13.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-13.mp3",
    "sentences": [
      {
        "text": "She felt like she was underwater and could not breathe.",
        "startTime": 0,
        "endTime": 4.032,
        "duration": 4.032,
        "sentenceIndex": 78
      },
      {
        "text": "She felt tired and thought she could not go on.",
        "startTime": 4.032,
        "endTime": 7.478,
        "duration": 3.446,
        "sentenceIndex": 79
      },
      {
        "text": "One day, Isabella got an email from a woman who bought her necklace.",
        "startTime": 7.478,
        "endTime": 12.614,
        "duration": 5.135,
        "sentenceIndex": 80
      },
      {
        "text": "The woman said, “Your jewelry is beautiful, and your story inspires me.",
        "startTime": 12.614,
        "endTime": 18.119,
        "duration": 5.505,
        "sentenceIndex": 81
      },
      {
        "text": "I am a single mother and your work gives me hope.” Isabella says thank you because that email changed everything for her.",
        "startTime": 18.119,
        "endTime": 26.99,
        "duration": 8.871,
        "sentenceIndex": 82
      },
      {
        "text": "She realized she was not just making jewelry.",
        "startTime": 26.99,
        "endTime": 30.289,
        "duration": 3.299,
        "sentenceIndex": 83
      }
    ],
    "totalDuration": 30.289206,
    "measuredDuration": 30.289206
  },
  {
    "bundleId": "b14",
    "bundleIndex": 14,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-2/A1/bundle-14.mp3",
    "audioPath": "single-parent-rising-2/A1/bundle-14.mp3",
    "sentences": [
      {
        "text": "She was building something.",
        "startTime": 0,
        "endTime": 1.901,
        "duration": 1.901,
        "sentenceIndex": 84
      },
      {
        "text": "She was creating something beautiful from nothing.",
        "startTime": 1.901,
        "endTime": 5.421,
        "duration": 3.52,
        "sentenceIndex": 85
      },
      {
        "text": "She was showing her children they could build a good life.",
        "startTime": 5.421,
        "endTime": 9.505,
        "duration": 4.083,
        "sentenceIndex": 86
      },
      {
        "text": "Isabella took a risk and hoped for good things.",
        "startTime": 9.505,
        "endTime": 12.814,
        "duration": 3.309,
        "sentenceIndex": 87
      },
      {
        "text": "She quit her night job and worked on her business at night.",
        "startTime": 12.814,
        "endTime": 16.968,
        "duration": 4.154,
        "sentenceIndex": 88
      },
      {
        "text": "Isabella worked hard and created new designs for her customers.",
