[
  {
    "bundleId": "b0",
    "bundleIndex": 0,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-0.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-0.mp3",
    "sentences": [
      {
        "text": "Lisa never thought her life would change so fast and so much.",
        "startTime": 0,
        "endTime": 4.373,
        "duration": 4.373,
        "sentenceIndex": 0
      },
      {
        "text": "One moment, she has a home, a job, and a family.",
        "startTime": 4.373,
        "endTime": 8.265,
        "duration": 3.891,
        "sentenceIndex": 1
      },
      {
        "text": "In the next moment, she has nothing at all.",
        "startTime": 8.265,
        "endTime": 11.497,
        "duration": 3.233,
        "sentenceIndex": 2
      },
      {
        "text": "It was a sunny Tuesday morning when it all began.",
        "startTime": 11.497,
        "endTime": 15.01,
        "duration": 3.513,
        "sentenceIndex": 3
      },
      {
        "text": "She was making breakfast for her children.",
        "startTime": 15.01,
        "endTime": 18.022,
        "duration": 3.011,
        "sentenceIndex": 4
      },
      {
        "text": "The smell of pancakes filled the air, and her kids laughed happily.",
        "startTime": 18.022,
        "endTime": 22.975,
        "duration": 4.953,
        "sentenceIndex": 5
      }
    ],
    "totalDuration": 22.975125,
    "measuredDuration": 22.975125
  },
  {
    "bundleId": "b1",
    "bundleIndex": 1,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-1.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-1.mp3",
    "sentences": [
      {
        "text": "But then, she received a phone call.",
        "startTime": 0,
        "endTime": 2.728,
        "duration": 2.728,
        "sentenceIndex": 6
      },
      {
        "text": "The phone rang loudly, breaking the joyful noise.",
        "startTime": 2.728,
        "endTime": 6.388,
        "duration": 3.659,
        "sentenceIndex": 7
      },
      {
        "text": "Her heart raced as she picked it up.",
        "startTime": 6.388,
        "endTime": 8.966,
        "duration": 2.578,
        "sentenceIndex": 8
      },
      {
        "text": "It was a strange voice on the line.",
        "startTime": 8.966,
        "endTime": 11.473,
        "duration": 2.507,
        "sentenceIndex": 9
      },
      {
        "text": "They said, \"I’m sorry, but your husband was in an accident.\" Lisa's world stopped in that moment.",
        "startTime": 11.473,
        "endTime": 18.72,
        "duration": 7.247,
        "sentenceIndex": 10
      },
      {
        "text": "She felt cold all over.",
        "startTime": 18.72,
        "endTime": 20.367,
        "duration": 1.647,
        "sentenceIndex": 11
      }
    ],
    "totalDuration": 20.366984,
    "measuredDuration": 20.366984
  },
  {
    "bundleId": "b2",
    "bundleIndex": 2,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-2.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-2.mp3",
    "sentences": [
      {
        "text": "Her husband was gone.",
        "startTime": 0,
        "endTime": 1.602,
        "duration": 1.602,
        "sentenceIndex": 12
      },
      {
        "text": "When Lisa reached the hospital, she felt scared and lost.",
        "startTime": 1.602,
        "endTime": 6.1,
        "duration": 4.498,
        "sentenceIndex": 13
      },
      {
        "text": "The hallways were bright, but her heart felt heavy.",
        "startTime": 6.1,
        "endTime": 10.14,
        "duration": 4.04,
        "sentenceIndex": 14
      },
      {
        "text": "The nurse took her to a small room.",
        "startTime": 10.14,
        "endTime": 12.809,
        "duration": 2.67,
        "sentenceIndex": 15
      },
      {
        "text": "She saw doctors and nurses talking, but no one could help her.",
        "startTime": 12.809,
        "endTime": 17.688,
        "duration": 4.879,
        "sentenceIndex": 16
      },
      {
        "text": "They told her the news.",
        "startTime": 17.688,
        "endTime": 19.443,
        "duration": 1.754,
        "sentenceIndex": 17
      }
    ],
    "totalDuration": 19.442744,
    "measuredDuration": 19.442744
  },
  {
    "bundleId": "b3",
    "bundleIndex": 3,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-3.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-3.mp3",
    "sentences": [
      {
        "text": "Her husband was dead.",
        "startTime": 0,
        "endTime": 1.686,
        "duration": 1.686,
        "sentenceIndex": 18
      },
      {
        "text": "Lisa was seven months pregnant.",
        "startTime": 1.686,
        "endTime": 4.175,
        "duration": 2.489,
        "sentenceIndex": 19
      },
      {
        "text": "Suddenly, she became a widow.",
        "startTime": 4.175,
        "endTime": 6.653,
        "duration": 2.478,
        "sentenceIndex": 20
      },
      {
        "text": "She felt alone and broken.",
        "startTime": 6.653,
        "endTime": 8.741,
        "duration": 2.087,
        "sentenceIndex": 21
      },
      {
        "text": "The weeks after were full of sadness and fear.",
        "startTime": 8.741,
        "endTime": 12.434,
        "duration": 3.693,
        "sentenceIndex": 22
      },
      {
        "text": "She cried many nights, holding her stomach.",
        "startTime": 12.434,
        "endTime": 16.036,
        "duration": 3.602,
        "sentenceIndex": 23
      }
    ],
    "totalDuration": 16.036077,
    "measuredDuration": 16.036077
  },
  {
    "bundleId": "b4",
    "bundleIndex": 4,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-4.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-4.mp3",
    "sentences": [
      {
        "text": "She thought about her baby.",
        "startTime": 0,
        "endTime": 2.051,
        "duration": 2.051,
        "sentenceIndex": 24
      },
      {
        "text": "“How can I do this alone?” she whispered.",
