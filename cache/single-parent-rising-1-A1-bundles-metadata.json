        "endTime": 18.178,
        "duration": 3.365,
        "sentenceIndex": 59
      }
    ],
    "totalDuration": 18.177846,
    "measuredDuration": 18.177846
  },
  {
    "bundleId": "b10",
    "bundleIndex": 10,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-10.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-10.mp3",
    "sentences": [
      {
        "text": "“I don’t know how to do this by myself.",
        "startTime": 0,
        "endTime": 2.86,
        "duration": 2.86,
        "sentenceIndex": 60
      },
      {
        "text": "I do not have the strength to go on.” She cried and asked for help until she had no tears.",
