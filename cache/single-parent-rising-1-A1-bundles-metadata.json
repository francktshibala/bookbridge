        "endTime": 20.15,
        "duration": 3.285,
        "sentenceIndex": 76
      },
      {
        "text": "They needed her to be strong and build a better life.",
        "startTime": 20.15,
        "endTime": 24.018,
        "duration": 3.869,
        "sentenceIndex": 77
      }
    ],
    "totalDuration": 24.018481,
    "measuredDuration": 24.018481
  },
