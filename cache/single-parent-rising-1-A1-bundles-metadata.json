    "bundleIndex": 10,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-10.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-10.mp3",
    "sentences": [
      {
        "text": "“I don’t know how to do this by myself.",
        "startTime": 0,
