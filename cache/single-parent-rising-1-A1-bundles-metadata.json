        "endTime": 8.266,
        "duration": 2.853,
        "sentenceIndex": 38
      },
      {
        "text": "Some nights, Lisa sits in her car and cries after work.",
        "startTime": 8.266,
        "endTime": 12.439,
        "duration": 4.173,
        "sentenceIndex": 39
      },
      {
        "text": "She feels invisible and alone when no one sees her.",
        "startTime": 12.439,
        "endTime": 16.169,
        "duration": 3.731,
        "sentenceIndex": 40
      },
      {
        "text": "The people she cleaned for did not know her name.",
        "startTime": 16.169,
        "endTime": 19.754,
        "duration": 3.584,
        "sentenceIndex": 41
      }
    ],
    "totalDuration": 19.753583,
    "measuredDuration": 19.753583
  },
  {
    "bundleId": "b7",
    "bundleIndex": 7,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-7.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-7.mp3",
    "sentences": [
