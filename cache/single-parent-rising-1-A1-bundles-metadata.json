        "endTime": 20.676,
        "duration": 2.665,
        "sentenceIndex": 47
      }
    ],
    "totalDuration": 20.675669,
    "measuredDuration": 20.675669
  },
  {
    "bundleId": "b8",
    "bundleIndex": 8,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-8.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-8.mp3",
    "sentences": [
      {
        "text": "Lisa wakes up at night and worries about money and her kids.",
