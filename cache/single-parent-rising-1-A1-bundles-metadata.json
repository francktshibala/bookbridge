    "audioPath": "single-parent-rising-1/A1/bundle-0.mp3",
    "sentences": [
      {
        "text": "Lisa never thought her life would change so fast and so much.",
        "startTime": 0,
        "endTime": 4.718,
        "duration": 4.718,
        "sentenceIndex": 0
      },
      {
        "text": "One moment, she has a home, a job, and a family.",
        "startTime": 4.718,
        "endTime": 8.88,
        "duration": 4.162,
        "sentenceIndex": 1
      },
      {
        "text": "In the next moment, she has nothing at all.",
        "startTime": 8.88,
        "endTime": 12.356,
        "duration": 3.476,
        "sentenceIndex": 2
      },
      {
        "text": "It was a sunny Tuesday morning when it all began.",
        "startTime": 12.356,
        "endTime": 16.145,
        "duration": 3.79,
        "sentenceIndex": 3
      },
      {
        "text": "She was making breakfast for her children.",
        "startTime": 16.145,
        "endTime": 19.393,
        "duration": 3.248,
        "sentenceIndex": 4
      },
      {
        "text": "The smell of pancakes filled the air, and her kids laughed happily.",
        "startTime": 19.393,
        "endTime": 24.725,
        "duration": 5.332,
        "sentenceIndex": 5
      }
    ],
    "totalDuration": 24.725079,
    "measuredDuration": 24.725079
  },
  {
    "bundleId": "b1",
    "bundleIndex": 1,
    "audioUrl": "https://xsolwqqdbsuydwmmwtsl.supabase.co/storage/v1/object/public/audio-files/single-parent-rising-1/A1/bundle-1.mp3",
    "audioPath": "single-parent-rising-1/A1/bundle-1.mp3",
    "sentences": [
      {
        "text": "But then, she received a phone call.",
        "startTime": 0,
        "endTime": 2.74,
        "duration": 2.74,
        "sentenceIndex": 6
      },
      {
        "text": "The phone rang loudly, breaking the joyful noise.",
