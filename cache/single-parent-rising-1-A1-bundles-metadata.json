        "sentenceIndex": 64
      },
      {
        "text": "He is six years old and has something in his hand.",
        "startTime": 19.949,
        "endTime": 23.616,
        "duration": 3.667,
        "sentenceIndex": 65
      }
    ],
    "totalDuration": 23.61576,
    "measuredDuration": 23.61576
  },
