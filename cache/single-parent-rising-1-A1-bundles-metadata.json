        "sentenceIndex": 20
      },
      {
        "text": "She felt alone and broken.",
        "startTime": 6.157,
        "endTime": 8.085,
        "duration": 1.928,
        "sentenceIndex": 21
      },
      {
        "text": "The weeks after were full of sadness and fear.",
        "startTime": 8.085,
        "endTime": 11.497,
        "duration": 3.411,
        "sentenceIndex": 22
      },
      {
        "text": "She cried many nights, holding her stomach.",
        "startTime": 11.497,
        "endTime": 14.836,
        "duration": 3.339,
        "sentenceIndex": 23
      }
    ],
    "totalDuration": 14.835782,
    "measuredDuration": 14.835782
  },
  {
    "bundleId": "b4",
    "bundleIndex": 4,
