        "sentenceIndex": 52
      },
      {
        "text": "One Friday night, Lisa knelt on her apartment floor.",
        "startTime": 19.201,
        "endTime": 23.363,
        "duration": 4.162,
        "sentenceIndex": 53
      }
    ],
    "totalDuration": 23.362608,
    "measuredDuration": 23.362608
  },
  {
    "bundleId": "b9",
    "bundleIndex": 9,
