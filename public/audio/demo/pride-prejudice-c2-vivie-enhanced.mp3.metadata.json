        "colonCount": 0,
        "emdashCount": 0,
        "ellipsisCount": 0
      }
    },
    {
      "sentenceIndex": 5,
      "text": "But it is, returned she; for Mrs. Long has just been here, and she told me all about it, relating every particular with the most minute attention to detail.",
      "startTime": 51.155,
      "endTime": 61.196,
      "duration": 10.041,
