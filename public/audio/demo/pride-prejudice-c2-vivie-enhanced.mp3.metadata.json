        "colonCount": 0,
        "emdashCount": 0,
        "ellipsisCount": 0
      }
    },
    {
      "sentenceIndex": 4,
      "text": "Mr. Bennet replied that he had not, maintaining his characteristic air of detached amusement at his wife's perpetual preoccupation with neighborhood affairs.",
      "startTime": 41.504,
      "endTime": 51.155,
      "duration": 9.651,
      "wordCount": 24,
      "complexity": {
