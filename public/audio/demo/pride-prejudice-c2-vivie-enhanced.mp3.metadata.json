        "colonCount": 0,
        "emdashCount": 0,
        "ellipsisCount": 0
      }
    },
    {
      "sentenceIndex": 6,
      "text": "Mr. Bennet made no answer, but continued perusing his book with studied indifference to the matrimonial intelligence his wife deemed so consequential.",
      "startTime": 61.196,
      "endTime": 70.423,
      "duration": 9.227,
      "wordCount": 24,
